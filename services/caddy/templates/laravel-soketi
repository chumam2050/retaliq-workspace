{$DOMAIN_NAME} {
	import app-cert-tls
	import waf
	import security-headers

	# 1. Vite HMR (Hot Module Replacement) - exclude from WAF
	@websocket {
		path /ws/*
	}
	handle @websocket {
		reverse_proxy APP_NAME:5171
	}

	# 2. Soketi WebSockets - exclude from WAF
	@soketi {
		path /socket/*
	}
	handle @soketi {
		uri strip_prefix /socket
		reverse_proxy soketi:6001
	}

	# 3. Everything else (Laravel/Web Server)
	handle {
		reverse_proxy APP_NAME:80 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Port {port}
			header_up Host {host}
		}
	}
}