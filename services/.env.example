# Roundcube Configuration
ROUNDCUBE_DB_TYPE=pgsql
ROUNDCUBE_DB_HOST=${POSTGRES_INTERNAL_HOST}
ROUNDCUBE_DB_PORT=${POSTGRES_PORT}
ROUNDCUBE_DB_USER=${POSTGRES_USER}
