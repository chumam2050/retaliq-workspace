# General Configuration
DOMAIN_NAME=retaliq.test
SSL_EMAIL_RENEWAL=admin@${DOMAIN_NAME}

RETALIQ_ENV=development
RETALIQ_DOMAIN_HOST=host.docker.internal
RETALIQ_DOMAIN_PORT=8888
RETALIQ_DOMAIN_API_KEY=1qAgWpjwwBOlZ7rhxgiGuwXSd71mF9li

# Database Configuration
# MARIADB_HOST / POSTGRES_HOST = localhost for CLI; internal Docker services use their
# container names (mariadb / postgres) via MARIADB_INTERNAL_HOST / POSTGRES_INTERNAL_HOST.
MARIADB_HOST=localhost
MARIADB_ROOT_PASSWORD=password
MARIADB_USER=app_user
MARIADB_PASSWORD=password
MARIADB_DATABASE=app_db

POSTGRES_HOST=localhost
POSTGRES_INTERNAL_HOST=postgres
POSTGRES_USER=app_user
POSTGRES_PASSWORD=password
POSTGRES_PORT=5432

# MinIO Configuration
# MINIO_ENDPOINT = localhost:9000 for CLI; Docker services use http://minio:9000 directly.
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BROWSER_REDIRECT_URL=http://minio.retaliq.test

# Soketi Configuration
SOKETI_APP_MANAGER_DRIVER=postgres
SOKETI_DB_POSTGRES_HOST=${POSTGRES_INTERNAL_HOST}
SOKETI_DB_POSTGRES_PORT=${POSTGRES_PORT}
SOKETI_DB_POSTGRES_USERNAME=${POSTGRES_USER}
SOKETI_DB_POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
SOKETI_DB_POSTGRES_DATABASE=soketi
SOKETI_DEFAULT_APP_ID=app-id
SOKETI_DEFAULT_APP_KEY=app-key
SOKETI_DEFAULT_APP_SECRET=app-secret

STALWART_HOSTNAME=mail.${DOMAIN_NAME}
STALWART_ADMIN_USER=admin
STALWART_ADMIN_PASSWORD=admin
STALWART_DB_HOST=${POSTGRES_INTERNAL_HOST}
STALWART_DB_PORT=${POSTGRES_PORT}
STALWART_DB_USER=${POSTGRES_USER}
STALWART_DB_PASSWORD=${POSTGRES_PASSWORD}
STALWART_DB_NAME=stalwart
STALWART_MINIO_ACCESS_KEY=${MINIO_ROOT_USER}
STALWART_MINIO_SECRET_KEY=${MINIO_ROOT_PASSWORD}
STALWART_MINIO_BUCKET=stalwart
STALWART_MINIO_ENDPOINT=http://minio:9000
STALWART_MINIO_REGION=us-east-1

